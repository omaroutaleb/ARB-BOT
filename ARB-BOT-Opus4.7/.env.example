# ===============================================================
# arbitrage-bot — environment configuration
# Copy to `.env` and fill in real values. NEVER commit .env.
# ===============================================================

# ----- General -----
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR
DRY_RUN=true                            # true = no real orders submitted (paper)
STRATEGY_PHASE=1                        # 1=Lim YES+NO only | 2=+Poly maker | 3=+cross-venue
METRICS_PORT=9090                       # Prometheus /metrics
STATE_FILE=/app/state/Trade.json        # Trade.json path inside container

# ----- Bankroll & risk (defaults from STRATEGY_SYNTHESIS §1.9) -----
BANKROLL_USD=500
MAX_POSITION_USD=40
MAX_CONCURRENT_ARBS=3
MAX_PLATFORM_EXPOSURE_USD=300
MIN_PLATFORM_RESERVE_USD=50
MIN_EDGE_DAILY_PCT=2.0
MIN_EDGE_1H_PCT=2.5
MIN_EDGE_30M_PCT=3.0
DAILY_LOSS_STOP_USD=50
TOTAL_DRAWDOWN_STOP_USD=150

# Phase promotion gates (read from state file)
PHASE2_MIN_CLOSED_ARBS=10
PHASE2_MIN_WIN_RATE=0.80
PHASE3_MIN_MAKER_FILLS=30

# ----- Polymarket (Polygon) -----
POLY_PRIVATE_KEY=                       # EOA / proxy private key (REQUIRED)
POLY_WALLET_ADDRESS=                    # Address derived from key OR proxy address
POLY_SIGNATURE_TYPE=0                   # 0=EOA | 1=POLY_PROXY | 2=POLY_GNOSIS_SAFE | 3=POLY_1271
POLY_CHAIN_ID=137
POLY_FUNDER_ADDRESS=                    # Required when SIGNATURE_TYPE != 0

# Polymarket hosts (override only if Polymarket changes them)
POLY_GAMMA_URL=https://gamma-api.polymarket.com
POLY_CLOB_URL=https://clob.polymarket.com
POLY_DATA_URL=https://data-api.polymarket.com
POLY_BRIDGE_URL=https://bridge.polymarket.com
POLY_WS_MARKET=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLY_WS_USER=wss://ws-subscriptions-clob.polymarket.com/ws/user
POLY_WS_RTDS=wss://ws-live-data.polymarket.com
POLY_GEOBLOCK_URL=https://polymarket.com/api/geoblock

# Heartbeat (Polymarket auto-cancels if absent >~15s)
POLY_HEARTBEAT_INTERVAL_SEC=5

# ----- Limitless (Base) -----
LIMITLESS_API_KEY=                      # lmts_... key from Profile → API Keys (REQUIRED)
LIMITLESS_PRIVATE_KEY=                  # Base EOA private key for EIP-712 order signing (REQUIRED)
LIMITLESS_WALLET_ADDRESS=               # Address derived from key
LIMITLESS_CHAIN_ID=8453
LIMITLESS_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

LIMITLESS_REST_URL=https://api.limitless.exchange
LIMITLESS_WS_URL=wss://ws.limitless.exchange

# Conservative rate limiter (Limitless doesn't publish numeric limits)
LIMITLESS_MAX_CONCURRENT=2
LIMITLESS_MIN_INTERVAL_MS=300

# ----- Docs validation -----
POLY_DOCS_LLMS=https://docs.polymarket.com/llms.txt
LIMITLESS_DOCS_LLMS=https://docs.limitless.exchange/llms.txt

# ----- Phase 1 (Limitless YES+NO complementarity) -----
PHASE1_EDGE_THRESHOLD=0.985             # ask(YES)+ask(NO) ≤ this triggers buy-side arb
PHASE1_MAX_POSITION_USD=20
PHASE1_MIN_24H_VOLUME_USD=1000
PHASE1_ALLOWED_DURATIONS=daily,hourly

# ----- Phase 2 (Polymarket maker rebate) -----
PHASE2_MARKETS=BTC                      # comma-separated assets
PHASE2_DURATIONS=15m
PHASE2_QUOTE_SIZE_USD=10
PHASE2_TICK_INSIDE=1                    # how many ticks inside best to quote

# ----- Phase 3 (cross-venue) -----
PHASE3_MIN_EDGE_PCT=3.0                 # gross divergence after oracle haircut
PHASE3_ORACLE_HAIRCUT_PCT=0.5
PHASE3_STRIKE_TOLERANCE_PCT=0.5
PHASE3_EXPIRY_TOLERANCE_SEC=3600
PHASE3_MAX_CONCURRENT=1
PHASE3_POSITION_USD=25
