# Runtime mode
DRY_RUN=true
STRATEGY_PHASE=1
ENABLE_CROSS_VENUE=false
LOG_LEVEL=INFO
DATA_DIR=./data
TRADE_JOURNAL_PATH=./Trade.json
DATABASE_PATH=./data/bot.sqlite3
METRICS_PORT=9090

# Bankroll and risk defaults for a $500 start
BANKROLL_USD=500
MAX_POSITION_USD=40
MAX_CONCURRENT_ARBS=3
MAX_SINGLE_PLATFORM_EXPOSURE_USD=300
RESERVE_CASH_USD=50
DAILY_LOSS_STOP_USD=-50
TOTAL_DRAWDOWN_STOP_USD=-150
ORACLE_MISMATCH_HAIRCUT_BPS=50

# Strategy thresholds
PHASE1_TRADE_SIZE_USD=20
PHASE2_MAKER_MIN_USD=5
PHASE2_MAKER_MAX_USD=10
PHASE3_CROSS_VENUE_MIN_USD=20
PHASE3_CROSS_VENUE_MAX_USD=30
EDGE_DAILY_BPS=200
EDGE_1H_BPS=250
EDGE_30M_BPS=300
LIMITLESS_COMPLEMENT_ASK_MAX=0.985

# Polymarket
POLYMARKET_PRIVATE_KEY=
POLYMARKET_ADDRESS=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_SIGNATURE_TYPE=0
POLYMARKET_FUNDER=
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_DATA_URL=https://data-api.polymarket.com
POLYMARKET_BRIDGE_URL=https://bridge.polymarket.com
POLYMARKET_GEOBLOCK_URL=https://polymarket.com/api/geoblock
POLYMARKET_MARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLYMARKET_USER_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/user
POLYMARKET_HEARTBEAT_SECONDS=5

# Limitless
LIMITLESS_API_KEY=
LIMITLESS_PRIVATE_KEY=
LIMITLESS_ADDRESS=
LIMITLESS_API_URL=https://api.limitless.exchange
LIMITLESS_WS_URL=wss://ws.limitless.exchange
LIMITLESS_REQUEST_MIN_DELAY_MS=300
LIMITLESS_MAX_CONCURRENT_REQUESTS=2

# Startup endpoint validation
VALIDATE_ENDPOINTS_ON_START=true
POLYMARKET_LLMS_URL=https://docs.polymarket.com/llms.txt
LIMITLESS_LLMS_URL=https://docs.limitless.exchange/llms.txt

